{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "types": ["@astrojs/image/client"],
    "baseUrl": ".",
    "paths": {
      "$assets/*": ["src/assets/*"],
      "$components/*": ["src/components/*"],
      "$content/*": ["src/content/*"],
      "$icons/*": ["src/icons/*"],
      "$interactive/*": ["src/components/interactive/*"],
      "$islands/*": ["src/components/islands/*"],
      "$layouts/*": ["src/layouts/*"],
      "$pages/*": ["src/pages/*"],
      "$styles/*": ["src/styles/*"],
      "$utils/*": ["src/utils/*"]
    }
  }
}
