---
import Layout from '$layouts/Base.astro'

import About from '$islands/About.astro'
import Footer from '$components/Footer.astro'
import Hero from '$islands/Hero.astro'
import Partners from '$islands/Partners.astro'
import Programme from '$islands/Programme.astro'
import Speakers from '$islands/Speakers.astro'
import Venue from '$islands/Venue.astro'


export async function getStaticPaths() {
  const sections = ['about', 'hero', 'partners', 'programme', 'speakers', 'venue']

  return sections.map((section) => { return { params: { section }}})
}

const { section } = Astro.params
---

<Layout>
  <Hero />
  <Programme />
  <Speakers />
  <Partners />
  <Venue />
  <About />
  <Footer />
</Layout>

