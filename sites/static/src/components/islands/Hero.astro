---
import { Image } from '@astrojs/image/components'

import logo from '$assets/logo.svg'
import Button from '$components/Button.astro'
import Navbar from '$components/Navbar.astro'

const summary = {
  speakers: 7,
  workshops: 3,
  venue: 'De Kom',
  location: 'Nieuwegein',
}
---

<Navbar>
  <p class="flex justify-center flex-auto order-first py-4 overflow-x-auto font-mono text-sm leading-relaxed text-center text-white basis-full sm:border-b sm:border-red/20 sm:py-4 sm:text-red lg:order-none lg:mx-0 lg:basis-auto lg:border-0 lg:py-0">
    <time>March 28, 2023</time>
    <span class="mx-2 text-white/60 sm:text-red/40">|&gt;</span>
    {summary.venue}
  </p>

  <Button slot="menu" size="medium" href="https://pretix.svsticky.nl/execut/2023/">
    Get your ticket!
  </Button>
</Navbar>

<header class="flex flex-col px-4 pb-16 lg:bp-28 sm:mx-auto sm:max-w-md sm:pb-20 md:max-w-2xl md:pb-24 lg:max-w-4xl">
  <Image class="w-64 m-auto mt-10 mb-16 sm:hidden" src={logo} alt="exec(ut) logo" />

  <h1 class="my-6 font-mono text-5xl font-bold text-red sm:mt-48 sm:text-6xl sm:leading-snug">
    A conference for and by IT students.
  </h1>

  <h2 class="my-2 text-2xl leading-snug text-red/80 sm:text-3xl sm:leading-normal">
    For those willing to look further than their own classroom. We want to work
    together, inspire each other, and commit ourselves to a better tomorrow.
    Besides a range of interesting talks exec(ut) provides great networking
    opportunities to those attending.
  </h2>

  <Button class="mx-auto mt-12 mb-16" size="large" href="https://pretix.svsticky.nl/execut/2023/">
    Get your ticket!
  </Button>

  <figure class="grid grid-cols-2 grid-rows-2 gap-x-2 gap-y-4 sm:gap-6">
    {Object.entries(summary).map(([title, figure]) => (
      <a class="sm:text-center" href={`#${title}`}>
        <span class="font-mono text-sm leading-none capitalize text-light-red">
          {title}
        </span>

        <p class="mt-2 text-xl font-bold text-brown">{figure}</p>
      </a>
    ))}
  </figure>
</header>
